    <Copy SourceFiles="@(DlssRuntimeFiles);@(StreamlineRuntimeFiles)" DestinationFolder="$(OutDir)Streamline\" SkipUnchangedFiles="true" Condition="'@(DlssRuntimeFiles);@(StreamlineRuntimeFiles)' != ''" />
