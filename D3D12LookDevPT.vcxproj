      <DxcDebug Condition="'$(Configuration)'=='Debug'">-Zi -Qembed_debug -Od</DxcDebug>
      <DxcDebug Condition="'$(Configuration)'!='Debug'">-O3</DxcDebug>
    </PropertyGroup>
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -T lib_6_6 -Fo &quot;$(CompiledShaderDir)PathTracing.lib.cso&quot; &quot;$(ProjectDir)Shaders\PathTracing.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -T lib_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingReSTIR.lib.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingReSTIR.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -T lib_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingReSTIRDI.lib.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingReSTIRDI.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -T lib_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingReSTIRCombined.lib.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingReSTIRCombined.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -E RestirTemporalSpatialCS -T cs_6_6 -Fo &quot;$(CompiledShaderDir)ReSTIRResolve.cso&quot; &quot;$(ProjectDir)Shaders\ReSTIRResolve.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -E RestirTemporalSpatialDICS -T cs_6_6 -Fo &quot;$(CompiledShaderDir)ReSTIRResolveDI.cso&quot; &quot;$(ProjectDir)Shaders\ReSTIRResolve.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -E DenoiseTemporalCS -T cs_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingDenoiseTemporal.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingDenoise.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -E DenoiseAtrous0CS -T cs_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingDenoiseAtrous0.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingDenoise.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -E DenoiseAtrous1CS -T cs_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingDenoiseAtrous1.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingDenoise.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -E DenoiseAtrous2CS -T cs_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingDenoiseAtrous2.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingDenoise.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -E DenoiseAtrous3CS -T cs_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingDenoiseAtrous3.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingDenoise.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -E DenoiseAtrous4CS -T cs_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingDenoiseAtrous4.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingDenoise.hlsl&quot;" />
    <Exec Command="&quot;$(DxcExe)&quot; $(DxcCommon) $(DxcDebug) -E DenoiseCompositeCS -T cs_6_6 -Fo &quot;$(CompiledShaderDir)PathTracingDenoiseComposite.cso&quot; &quot;$(ProjectDir)Shaders\PathTracingDenoise.hlsl&quot;" />
